# Provider API keys (recommended to set via AI → API Keys…)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional default model used when a session does not specify one
BRILLIANTCODE_DEFAULT_MODEL=gpt-5.2

# Optional: Google Custom Search for the `google_search` tool
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Optional: auto-updater feed (leave unset to disable auto-updates)
BRILLIANTCODE_UPDATE_FEED_URL=

# Optional: version check endpoint (leave unset to disable version checks)
BRILLIANTCODE_VERSION_CHECK_URL=

# ============================================================================
# Codex Authentication (Sign in with ChatGPT)
# ============================================================================
# BrilliantCode uses the official Codex app-server for authentication.
# No environment variables are required - just install the Codex CLI:
#
#   npm install -g @anthropic/codex
#
# Then use "Sign in with ChatGPT" in the AI → API Keys dialog.
# See docs/CODEX_AUTH.md for more information.
